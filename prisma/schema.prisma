generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                String   @id @default(cuid())
  name              String?
  email             String   @unique
  password          String
  plan              String   @default("Gratuit")
  searchesRemaining Int      @default(5)
  active            Boolean  @default(true)
  createdAt         DateTime @default(now())
  searches          Search[]
  emailsSent        EmailSent[]
  favorites         Favorite[]
}

model Search {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  niche     String
  language  String
  subsMin   String
  subsMax   String
  results   String
  createdAt DateTime @default(now())
}

model EmailSent {
  id           String   @id @default(cuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id])
  channelName  String
  channelEmail String
  content      String
  status       String   @default("Envoyé")
  createdAt    DateTime @default(now())
}

model Favorite {
  id               String   @id @default(cuid())
  userId           String
  user             User     @relation(fields: [userId], references: [id])
  channelId        String
  name             String
  subs             String?
  subsNum          Int?
  niche            String?
  lang             String?
  score            Int?
  scoreLabel       String?
  scoreReason      String?
  email            String?
  instagram        String?
  tiktok           String?
  twitch           String?
  website          String?
  channelUrl       String?
  aboutUrl         String?
  desc             String?
  avatar           String?
  color            String?
  thumbnail        String?
  totalViews       Float?
  videoCount       Int?
  channelCreatedAt DateTime?
  createdAt        DateTime @default(now())

  @@unique([userId, channelId])
}
