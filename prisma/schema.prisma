generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model User {
  id                 String   @id @default(cuid())
  name               String?
  email              String   @unique
  password           String
  plan               String   @default("Gratuit")
  searchesRemaining  Int      @default(5)
  createdAt          DateTime @default(now())
  searches           Search[]
  emailsSent         EmailSent[]
}

model Search {
  id        String   @id @default(cuid())
  userId    String
  niche     String
  language  String
  subsMin   String
  subsMax   String
  results   String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])
}

model EmailSent {
  id           String   @id @default(cuid())
  userId       String
  channelName  String
  channelEmail String
  content      String
  status       String   @default("Envoyé")
  createdAt    DateTime @default(now())
  user         User     @relation(fields: [userId], references: [id])
}
